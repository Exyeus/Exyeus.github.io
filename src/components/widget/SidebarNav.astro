---
import { Icon } from "astro-icon/components";
import { navBarConfig, siteConfig } from "../../config";
import { LinkPresets } from "../../constants/link-presets";
import { LinkPreset, type NavBarLink } from "../../types/config";
import { pathsEqual, url } from "../../utils/url-utils";
import LightDarkSwitch from "../LightDarkSwitch.svelte";
import Search from "../Search.svelte";
import DisplaySettings from "./DisplaySettings.svelte";

let links: NavBarLink[] = navBarConfig.links.map(
	(item: NavBarLink | LinkPreset): NavBarLink => {
		if (typeof item === "number") {
			return LinkPresets[item];
		}
		return item;
	},
);

const currentPath = Astro.url.pathname;
---

<div class="card-base p-3">
	<a
		href={url("/")}
		class="btn-plain scale-animation rounded-xl h-12 px-3 font-bold active:scale-95 justify-start"
	>
		<div class="flex flex-row text-[var(--primary)] items-center text-md">
			<Icon name="material-symbols:home-outline-rounded" class="text-[1.5rem] mr-2" />
			{siteConfig.title}
		</div>
	</a>

	<div class="mt-2 flex flex-col gap-1">
		{links.map((link) => {
			const isCurrent = !link.external && pathsEqual(currentPath, link.url);
			return (
				<a
					aria-label={link.name}
					href={link.external ? link.url : url(link.url)}
					target={link.external ? "_blank" : null}
					class:list={[
						"btn-plain scale-animation rounded-xl h-10 px-3 font-semibold active:scale-95 justify-start",
						{ "current-theme-btn": isCurrent },
					]}
				>
					<div class="flex items-center">
						{link.name}
						{link.external && (
							<Icon
								name="fa6-solid:arrow-up-right-from-square"
								class="text-[0.875rem] transition -translate-y-[1px] ml-1 text-black/[0.2] dark:text-white/[0.2]"
							></Icon>
						)}
					</div>
				</a>
			);
		})}
	</div>

	<div class="mt-3 flex items-center gap-2">
		<Search client:only="svelte"></Search>
		{
			!siteConfig.themeColor.fixed && (
				<button
					aria-label="Display Settings"
					class="btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90 shrink-0"
					id="display-settings-switch"
				>
					<Icon name="material-symbols:palette-outline" class="text-[1.25rem]"></Icon>
				</button>
			)
		}
		<LightDarkSwitch client:only="svelte"></LightDarkSwitch>
	</div>
	<DisplaySettings client:only="svelte"></DisplaySettings>
</div>

<script>
function loadSidebarButtonScript() {
	const settingBtn = document.getElementById("display-settings-switch");
	if (!settingBtn) return;

	settingBtn.onclick = function () {
		const settingPanel = document.getElementById("display-setting");
		if (settingPanel) {
			settingPanel.classList.toggle("float-panel-closed");
		}
	};
}

loadSidebarButtonScript();
</script>

{
	import.meta.env.PROD && (
		<script is:inline define:vars={{ scriptUrl: url("/pagefind/pagefind.js") }}>
			async function loadPagefind() {
				try {
					const response = await fetch(scriptUrl, { method: "HEAD" });
					if (!response.ok) {
						throw new Error(`Pagefind script not found: ${response.status}`);
					}

					const pagefind = await import(scriptUrl);
					await pagefind.options({
						excerptLength: 20,
					});

					window.pagefind = pagefind;
					document.dispatchEvent(new CustomEvent("pagefindready"));
				} catch (error) {
					console.error("Failed to load Pagefind:", error);
					window.pagefind = {
						search: () => Promise.resolve({ results: [] }),
						options: () => Promise.resolve(),
					};
					document.dispatchEvent(new CustomEvent("pagefindloaderror"));
				}
			}

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", loadPagefind);
			} else {
				loadPagefind();
			}
		</script>
	)
}
